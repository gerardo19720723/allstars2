datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum OrderStatus {
  PENDING     
  IN_PROGRESS 
  READY       
  SERVED      
  PAID        
  CANCELLED   
}

enum UserRole {
  ADMIN    // Gerente / Dueño
  STAFF    // Meseros
  KITCHEN  // Cocina / Barra
}

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  users     User[]
  categories Category[]
  products Product[]
  orders    Order[]
  guests        Guest[]
  guestLists    GuestList[]
  accessLogs    AccessLog[]
  createdAt DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  role      UserRole @default(STAFF)
  orders    Order[]
}

model Category {
  id        String    @id @default(cuid())
  name      String
  tenantId  String    // Las categorías también son por antro
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  products  Product[] // Una categoría tiene muchos productos
  createdAt DateTime  @default(now())
}

model Product {
  id          String   @id @default(cuid())
  name        String
  price       Decimal  @db.Decimal(10, 2)
  description String?
  tenantId    String 
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  categoryId  String?  // Opcional por ahora para no romper productos viejos
  category    Category? @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
  createdAt   DateTime @default(now())
}

model Order {
  id        String      @id @default(cuid())
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  userId    String?     // Opcional: para invitados
  user      User?       @relation(fields: [userId], references: [id])
  status    OrderStatus @default(PENDING)
  total     Decimal     @default(0) @db.Decimal(10, 2)
  items     OrderItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int      @default(1)
  price     Decimal  @db.Decimal(10, 2) // Guardamos el precio al momento de comprar
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])
}

model Guest {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  name          String?   // Nombre del cliente
  email         String?   // Si tiene cuenta
  status        String    @default("CHECKED_IN") // CHECKED_IN, DENIED, LEFT
  ticketType    String?   // VIP, GENERAL, STAFF
  entryTime     DateTime  @default(now())
  accessLogs    AccessLog[]
  
  @@index([tenantId, status])
}

model GuestList {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  name          String
  guestCount    Int      // Cuántas personas trae
  note          String?  // Ej: "Cumpleaños", "Mesa VIP"
  isVip         Boolean  @default(false)
  expectedAt    DateTime // A qué hora se espera
  createdAt     DateTime @default(now())
  
  @@index([tenantId, expectedAt])
}

model AccessLog {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  guestId      String?
  guest         Guest?   @relation(fields: [guestId], references: [id])
  action        String   // CHECK_IN, DENIED
  reason        String?  // Por qué se le negó (ej: "Aforo lleno")
  timestamp     DateTime @default(now())
}