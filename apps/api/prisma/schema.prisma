datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum OrderStatus {
  PENDING     
  IN_PROGRESS 
  READY       
  SERVED      
  PAID        
  CANCELLED   
}

enum UserRole {
  ADMIN    // Gerente / Dueño
  STAFF    // Meseros
  KITCHEN  // Cocina / Barra
}

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  users     User[]
  categories Category[]
  products Product[]
  orders    Order[]
  guests        Guest[]
  guestLists    GuestList[]
  accessLogs    AccessLog[]
  djSessions    DjSession[]
  customers Customer[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  genres       Genre[]
  genreSessions GenreSession[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  role      UserRole @default(STAFF)
  djSessions  DjSession[]
}

model Customer {
  id        String   @id @default(cuid())
  
  // Datos de Fidelización (Loyalty)
  email     String?  // Opcional al principio, obligatorio si se registran
  phone     String?  // Para enviar notificaciones o login
  points    Int      @default(0) // <--- AQUÍ EMPIEZA TU FIDELIZACIÓN
  
  // Relación con el Local (Tenant)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  
  // Comportamiento del Cliente
  votes     CustomerVote[]
  orders    Order[]  // Los pedidos reales (bebidas/comida)
  genreVotes GenreVote[]
  createdAt DateTime @default(now())
}

model Category {
  id        String    @id @default(cuid())
  name      String
  tenantId  String    // Las categorías también son por antro
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  products  Product[] // Una categoría tiene muchos productos
  createdAt DateTime  @default(now())
}

model Product {
  id          String   @id @default(cuid())
  name        String
  price       Decimal  @db.Decimal(10, 2)
  description String?
  tenantId    String 
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  categoryId  String?  // Opcional por ahora para no romper productos viejos
  category    Category? @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
  createdAt   DateTime @default(now())
}

model Order {
  id        String      @id @default(cuid())
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  status    OrderStatus @default(PENDING)
  total     Decimal     @default(0) @db.Decimal(10, 2)
  items     OrderItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int      @default(1)
  price     Decimal  @db.Decimal(10, 2) // Guardamos el precio al momento de comprar
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])
}

model Guest {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  name          String?   // Nombre del cliente
  email         String?   // Si tiene cuenta
  status        String    @default("CHECKED_IN") // CHECKED_IN, DENIED, LEFT
  ticketType    String?   // VIP, GENERAL, STAFF
  entryTime     DateTime  @default(now())
  accessLogs    AccessLog[]
  
  @@index([tenantId, status])
}

model GuestList {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  name          String
  guestCount    Int      // Cuántas personas trae
  note          String?  // Ej: "Cumpleaños", "Mesa VIP"
  isVip         Boolean  @default(false)
  expectedAt    DateTime // A qué hora se espera
  createdAt     DateTime @default(now())
  
  @@index([tenantId, expectedAt])
}

model AccessLog {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  guestId      String?
  guest         Guest?   @relation(fields: [guestId], references: [id])
  action        String   // CHECK_IN, DENIED
  reason        String?  // Por qué se le negó (ej: "Aforo lleno")
  timestamp     DateTime @default(now())
}

model DjSession {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  djUserId      String?  // Si hay un DJ registrado logueado
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  isActive      Boolean  @default(true)
  currentVibe   String?  // "Techno", "Reggaeton", etc.
  requests      SongRequest[]
   createdAt     DateTime @default(dbgenerated("now()"))
}

model SongRequest {
  id            String   @id @default(cuid())
  sessionId     String
  session       DjSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  songUri       String   // URI de Spotify (ej: "spotify:track:...")
  songTitle     String   // Título visible
  artistName    String   // Artista visible
  status        String   @default("PENDING") // PENDING, APPROVED, PLAYED, REJECTED, SKIPPED
  isPriority    Boolean  @default(false) // Si pagó para saltar la cola
  votes         Int      @default(0)
  playedAt      DateTime?
  createdAt     DateTime @default(dbgenerated("now()"))

  @@index([sessionId, status])
}

model CustomerVote {
  id        String   @id @default(cuid())
  requestId String
  customerId String
  customer  Customer @relation(fields: [customerId], references: [id])
  
  @@unique([requestId, customerId])
}

model Genre {
  id        String   @id @default(cuid())
  name      String   // Ej: "Reggaeton", "House", "Salsa"
  emoji     String?  // Ej: "🔥", "🎹"
  
  // Relación con el Tenant (Un local puede tener sus géneros favoritos)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  
  // Relación con las votaciones
  votes     GenreVote[]
  
  @@unique([name, tenantId]) // Un Tenant no puede tener 2 géneros con mismo nombre
}

model GenreSession {
  id        String   @id @default(cuid())
  isActive  Boolean  @default(true) // Si true, los clientes ven la batalla
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  
  // Relación con los votos realizados en esta sesión
  votes     GenreVote[]
}

model GenreVote {
  id        String   @id @default(cuid())
  
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  
  genreId     String
  genre       Genre    @relation(fields: [genreId], references: [id])
  
  sessionId   String // A qué "Round" pertenece este voto
  session     GenreSession @relation(fields: [sessionId], references: [id])
  
  createdAt   DateTime @default(now())
  
  // Un cliente solo puede votar UNA vez por sesión de batalla
  @@unique([customerId, sessionId])
}
